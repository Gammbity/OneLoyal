JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
ENCRYPTION_KEY=mG9F8sFFMykNhnO-c-vHl09MBBihRLNCrVyBRDXv3Hw=
LOG_LEVEL=INFO
PAGINATION_DEFAULT_LIMIT=50
PAGINATION_MAX_LIMIT=200
PASSWORD_HASH_TIME_COST=3
