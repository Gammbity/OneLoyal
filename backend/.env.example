APP_NAME=OneLoyal API
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL=postgresql+asyncpg://oneloyal:oneloyal@postgres:5432/oneloyal
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

SECRET_KEY=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
LOG_LEVEL=INFO

POSTGRES_DB=oneloyal
POSTGRES_USER=oneloyal
POSTGRES_PASSWORD=oneloyal

